# Build context = repo root (npm workspaces; single root package-lock.json).
# Keep the context small: never ship installed deps, build output, VCS, or env.

**/node_modules
**/.next
**/dist
**/*.tsbuildinfo
**/coverage

.git
.github
.husky
.idea
.vscode
.claude
.playwright-mcp
frontend/test-results
frontend/e2e
frontend/undefined

**/*.cpuprofile
*.png
# ...but the backend ships the app logo as a runtime asset (the bot attaches it
# to the /start welcome), so it must stay in the build context.
!backend/assets/logo.png

backups

# Never bake env files into an image (secrets are injected at runtime).
.env
.env.*
!.env.example
