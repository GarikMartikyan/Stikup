# --- Node environment ---
NODE_ENV=development

# --- Postgres (docker-compose) ---
POSTGRES_USER=stickup
POSTGRES_PASSWORD=stickup
POSTGRES_DB=stickup
POSTGRES_PORT=5432

# --- Database (Prisma / backend runtime) ---
DATABASE_URL=postgresql://stickup:stickup@localhost:5432/stickup?schema=public

# --- Backend ---
PORT=3131
TELEGRAM_BOT_TOKEN=changeme

# Public URL the BROWSER will hit (the frontend origin).
# In dev/compose this is http://localhost:3000.
# In prod, your real https URL.
PUBLIC_APP_URL=http://localhost:3000
POST_LOGIN_PATH=/my-stickers

SESSION_COOKIE_NAME=sid
# Set to true in production behind HTTPS.
SESSION_COOKIE_SECURE=false
# Leave empty for host-only cookies. Set e.g. .example.com to share across subdomains.
SESSION_COOKIE_DOMAIN=

# --- Frontend ---
FRONTEND_PORT=3000
FRONTEND_HOST=localhost
FRONTEND_USE_HTTPS=false

# Backend origin the frontend talks to (server-side rewrites + SSR fetches).
BACKEND_URL=http://localhost:3131
# Telegram bot URL shown on login/register pages (client-visible).
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/stikup_bot

# --- AI image provider ---
# Which backend generates sticker images. 'stub' returns a fixed test image.
# Future values may include real providers (e.g. 'openai', 'replicate').
AI_PROVIDER=stub

# --- Redis (BullMQ queue) ---
REDIS_URL=redis://localhost:6379

# --- Google OAuth ---
# Create credentials at https://console.cloud.google.com/apis/credentials
# Redirect URI must match exactly what is registered in the Google Console.
GOOGLE_CLIENT_ID=changeme
GOOGLE_CLIENT_SECRET=changeme
GOOGLE_REDIRECT_URI=http://localhost:3131/auth/google/callback

# --- Offer / pricing config ---
# All values are optional; defaults match the product's current offer.
OFFER_PRICE_LABEL=$5
OFFER_PRICE_CENTS=500
OFFER_CURRENCY=USD
# Number of stickers in a full pack.
OFFER_PACK_SIZE=12
# Stickers shown for free before purchase.
OFFER_FREE_STICKER_COUNT=3
# Extra generations granted by a one-time $5 unlock.
OFFER_PAID_GENERATIONS=10
# Lifetime free-trial generations.
OFFER_FREE_GENERATIONS=1
OFFER_FREE_REGENERATIONS=1
# Set to false to disable the referral-based free unlock flow.
OFFER_REFERRAL_UNLOCK=true
