# =====================================================================
#  Stikup — environment configuration reference
# =====================================================================
#
#  Files (loaded most-specific first; FIRST match wins):
#    .env.<env>.local   real secrets, GITIGNORED       (you create these)
#    .env.<env>         committed per-env template      (placeholders)
#    .env               legacy local fallback           (gitignored)
#
#  <env> is chosen by APP_ENV (falls back to NODE_ENV):
#    development | production | test
#
#  Quick start (dev): put your real TELEGRAM_BOT_TOKEN and GOOGLE_*
#  into .env.development.local — everything else has a safe default in
#  the committed .env.development.
#
#  Production: set real values in .env.production.local ON THE SERVER
#  (never commit). See docs for the deploy flow.
# =====================================================================

# --- Environment ---
APP_ENV=development            # development | production | test
NODE_ENV=development

# --- Postgres ---
POSTGRES_USER=stickup
POSTGRES_PASSWORD=changeme
POSTGRES_DB=stickup
POSTGRES_PORT=5432

# --- Database (Prisma / backend runtime) ---
DATABASE_URL=postgresql://stickup:changeme@localhost:5432/stickup?schema=public

# --- Backend ---
PORT=3131
TELEGRAM_BOT_TOKEN=changeme
# Launch the bot's long-polling loop (getUpdates). Telegram permits only one
# poller per token: keep this false locally so you don't crash with a 409
# Conflict against the live bot. Sending still works with it off. Defaults to
# true in production, false otherwise.
# TELEGRAM_BOT_LAUNCH=false
# How long (in seconds) a Telegram Mini App initData HMAC is considered fresh.
# Default: 86400 (24 h). Lower in production for tighter replay protection.
# TELEGRAM_INITDATA_MAX_AGE_SEC=86400
# Override the Mini App launch URL (must be HTTPS in production).
# Defaults to ${PUBLIC_APP_URL}/app when not set.
# TELEGRAM_MINI_APP_URL=https://stikup.app/app

# Browser-facing app origin (the frontend).
# Dev: http://localhost:3000   Prod: https://yourdomain
PUBLIC_APP_URL=http://localhost:3000
POST_LOGIN_PATH=/my-stickers

SESSION_COOKIE_NAME=sid
# Auto-defaults to true when APP_ENV=production (HTTPS required there).
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=

# --- Frontend ---
FRONTEND_PORT=3000
FRONTEND_HOST=localhost
FRONTEND_USE_HTTPS=false
# Prod only: explicit public URL if PUBLIC_APP_URL isn't set.
# FRONTEND_URL=https://yourdomain

BACKEND_URL=http://localhost:3131
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/stikup_bot

# --- AI image generation ---
# 'stub' returns a fixed test image; no API key needed.
# Set AI_PROVIDER=openai and a real OPENAI_API_KEY for real generation.
AI_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_SIZE=1536x1024
# Optional tuning (defaults shown). quality: low|medium|high|auto — higher gives
# cleaner gutters between the 12 cells (better split) but costs more.
# input_fidelity: high|low — 'high' makes the chibi resemble the uploaded person.
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_INPUT_FIDELITY=high
# Where generated sticker files are written. Leave unset to use the app default
# (backend/public/packs). In Docker the compose volume sets this explicitly.
# STICKER_STORAGE_DIR=

# --- Redis (BullMQ queue) ---
REDIS_URL=redis://localhost:6379

# --- Google OAuth ---
GOOGLE_CLIENT_ID=changeme
GOOGLE_CLIENT_SECRET=changeme
GOOGLE_REDIRECT_URI=http://localhost:3131/auth/google/callback

# --- Sticker delivery config ---
# Default emoji applied to every sticker in a Telegram sticker set.
STICKER_DEFAULT_EMOJI=😀

# --- Offer / pricing config (optional; defaults shown) ---
OFFER_PRICE_LABEL=$5
OFFER_PRICE_CENTS=500
OFFER_CURRENCY=USD
OFFER_PACK_SIZE=12
OFFER_FREE_STICKER_COUNT=3
OFFER_PAID_GENERATIONS=10
OFFER_FREE_GENERATIONS=1
OFFER_FREE_REGENERATIONS=1
OFFER_REFERRAL_UNLOCK=true
