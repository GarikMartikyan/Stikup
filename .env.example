# --- Postgres ---
POSTGRES_USER=stickup
POSTGRES_PASSWORD=stickup
POSTGRES_DB=stickup
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=3131
TELEGRAM_BOT_TOKEN=changeme

# Public URL the BROWSER will hit (the frontend origin).
# In dev/compose this is http://localhost:3000.
# In prod, your real https URL.
PUBLIC_APP_URL=http://localhost:3000
POST_LOGIN_PATH=/dashboard

SESSION_COOKIE_NAME=sid
# Set to true in production behind HTTPS.
SESSION_COOKIE_SECURE=false
# Leave empty for host-only cookies. Set e.g. .example.com to share across subdomains.
SESSION_COOKIE_DOMAIN=

# --- Frontend ---
FRONTEND_PORT=3000
