generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Channel {
  telegram
  whatsapp
  email
  google
}

enum TokenPurpose {
  login
  link
}

enum PackStatus {
  generating
  ready
  failed
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  email              String?   @unique
  passwordHash       String?   @map("password_hash")
  referralCode       String?   @unique @map("referral_code")
  fullPackUnlockedAt DateTime? @map("full_pack_unlocked_at") @db.Timestamptz(6)
  generationsUsed    Int       @default(0) @map("generations_used")
  // Set the first time the user "accepts" a pack — gets it on Telegram,
  // downloads it, or unlocks it. Once set, generation/regeneration is locked.
  generationLockedAt DateTime? @map("generation_locked_at") @db.Timestamptz(6)

  identities       ChannelIdentity[]
  loginTokens      LoginToken[]
  sessions         Session[]
  packs            Pack[]
  referralsMade    Referral[]        @relation("referrer")
  referralReceived Referral?         @relation("referred")

  @@map("users")
}

model ChannelIdentity {
  id            String   @id @default(uuid()) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  channel       Channel
  channelUserId String   @map("channel_user_id")
  displayName   String?  @map("display_name")
  username      String?
  avatarUrl     String?  @map("avatar_url")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channel, channelUserId])
  @@index([userId])
  @@map("channel_identities")
}

model LoginToken {
  token             String       @id
  userId            String       @map("user_id") @db.Uuid
  issuedVia         Channel      @map("issued_via")
  purpose           TokenPurpose @default(login) @map("purpose")
  expiresAt         DateTime     @map("expires_at") @db.Timestamptz(6)
  consumedAt        DateTime?    @map("consumed_at") @db.Timestamptz(6)
  createdAt         DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  telegramChatId        BigInt?  @map("telegram_chat_id")
  telegramMessageId     Int?     @map("telegram_message_id")
  telegramUserMessageId Int?     @map("telegram_user_message_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
  @@map("login_tokens")
}

model Session {
  id         String    @id
  userId     String    @map("user_id") @db.Uuid
  issuedVia  Channel   @map("issued_via")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt  DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PackClaim {
  packId      String   @map("pack_id")
  userId      String   @map("user_id") @db.Uuid
  deliveredAt DateTime @default(now()) @map("delivered_at") @db.Timestamptz(6)
  channel     Channel

  @@id([packId, userId])
  @@index([userId])
  @@map("pack_claims")
}

model Pack {
  id                     String     @id @default(uuid()) @db.Uuid
  userId                 String     @map("user_id") @db.Uuid
  status                 PackStatus @default(ready)
  createdAt              DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  telegramStickerSetName String?    @map("telegram_sticker_set_name")
  telegramStickerCount   Int        @default(0) @map("telegram_sticker_count")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stickers Sticker[]

  @@index([userId])
  @@map("packs")
}

model Sticker {
  id        String   @id @default(uuid()) @db.Uuid
  packId    String   @map("pack_id") @db.Uuid
  index     Int
  url       String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  pack Pack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@unique([packId, index])
  @@index([packId])
  @@map("stickers")
}

model Referral {
  id             String   @id @default(uuid()) @db.Uuid
  referrerId     String   @map("referrer_id") @db.Uuid
  referredUserId String   @unique @map("referred_user_id") @db.Uuid
  channel        Channel
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  referrer User @relation("referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("referred", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@map("referrals")
}
